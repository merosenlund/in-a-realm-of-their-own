[sub_resource type="GDScript" id="GDScript_core"]
script/source = "extends Node3D

@export var condensation_rate: float = 2.0

func _process(delta):
	# The core condenses ambient mana into the global pool
	ManaManager.current_mana += condensation_rate * delta
"

